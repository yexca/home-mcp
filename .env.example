# Copy this file to .env before running Docker Compose.
# Keep .env local; do not commit real tokens or provider secrets.

GATEWAY_TOKEN_HOST=change-me
GATEWAY_TOKEN_ROLE_DEFAULT=change-me-role
ARTIFACT_SIGNING_SECRET=change-me-artifact-signing-secret

SERVER_HOST=0.0.0.0
SERVER_PORT=8787

ARTIFACT_ROOT=./artifacts
# Fallback artifact URL returned when the gateway cannot derive one from the
# request Host header. For mixed host/container access, this can be set to one
# unified address that both sides can fetch, such as
# http://192.168.1.23:8787/artifacts.
ARTIFACT_PUBLIC_BASE_URL=http://127.0.0.1:8787/artifacts
ARTIFACT_SIGNED_URL_TTL_SECONDS=300
MAX_ARTIFACT_BYTES=52428800
MAX_INLINE_ARTIFACT_BYTES=5242880

DATABASE_PATH=./artifacts/metadata.sqlite3
DATABASE_BUSY_TIMEOUT_MS=5000

SYNC_TOOL_TIMEOUT_SECONDS=120
IMAGE_JOBS_PER_CALLER_PER_DAY=20
TTS_JOBS_PER_CALLER_PER_DAY=100
PRINT_JOBS_PER_CALLER_PER_DAY=20
MAX_IMAGE_JOBS_GLOBAL=2
MAX_IMAGE_JOBS_PER_CALLER=1
MAX_TTS_JOBS_GLOBAL=2
MATRIX_MESSAGES_PER_ROOM_PER_MINUTE=5
MAX_PRINT_JOBS_GLOBAL=1

# Optional runtime overrides for module availability. Leave empty to use YAML.
IMAGE_MODULE_ENABLED=
LOCAL_IMAGE_MODULE_ENABLED=
TTS_MODULE_ENABLED=
MATRIX_MODULE_ENABLED=
PRINTER_MODULE_ENABLED=

# Optional provider settings. Leave empty unless the matching module is enabled.
#
# Image provider base URL is the OpenAI-compatible API root. Do not include
# /v1/images here; the gateway appends /v1/images/generations and
# /v1/images/edits itself.
#
# Example:
# IMAGE_API_BASE_URL=https://api.example.com
IMAGE_API_BASE_URL=
IMAGE_API_MODEL=your-image-model
IMAGE_API_KEY=
IMAGE_TOTAL_TIMEOUT_SECONDS=600
IMAGE_STALE_JOB_GRACE_SECONDS=30
IMAGE_PROVIDER_TIMEOUT_SECONDS=60
IMAGE_MAX_DOWNLOAD_BYTES=10485760
IMAGE_MAX_EDIT_INPUT_IMAGES=4
IMAGE_MAX_EDIT_INPUT_IMAGE_BYTES=10485760
IMAGE_MAX_EDIT_TOTAL_IMAGE_BYTES=20971520

# Local ComfyUI image generation. These values are used only when
# modules.localimage.enabled is true.
LOCAL_IMAGE_DEFAULT_SIZE=1024x1024
LOCAL_IMAGE_DEFAULT_QUALITY=standard
LOCAL_IMAGE_DEFAULT_STYLE=default
LOCAL_IMAGE_DEFAULT_OUTPUT_FORMAT=png
LOCAL_IMAGE_TOTAL_TIMEOUT_SECONDS=900
LOCAL_IMAGE_STALE_JOB_GRACE_SECONDS=30
LOCAL_IMAGE_COMFYUI_BASE_URL=http://127.0.0.1:8188
LOCAL_IMAGE_COMFYUI_ALLOWED_HOST=127.0.0.1
LOCAL_IMAGE_COMFYUI_WORKFLOW_PATH=./config/comfyui/sdxl_text_to_image.example.json
LOCAL_IMAGE_COMFYUI_CHECKPOINT=your-checkpoint.safetensors
LOCAL_IMAGE_COMFYUI_UNET_NAME=
LOCAL_IMAGE_COMFYUI_CLIP_NAME=
LOCAL_IMAGE_COMFYUI_VAE_NAME=
LOCAL_IMAGE_COMFYUI_TIMEOUT_SECONDS=30
LOCAL_IMAGE_COMFYUI_POLL_INTERVAL_SECONDS=1
LOCAL_IMAGE_COMFYUI_MAX_WAIT_SECONDS=900

# Anima workflow option. Uncomment these values to switch localimage to the
# Anima workflow exported from sample/anima.json.
# LOCAL_IMAGE_COMFYUI_WORKFLOW_PATH=./config/comfyui/anima_text_to_image.example.json
# LOCAL_IMAGE_COMFYUI_CHECKPOINT=
# LOCAL_IMAGE_COMFYUI_UNET_NAME=miaomiaoRealskin_anima10.safetensors
# LOCAL_IMAGE_COMFYUI_CLIP_NAME=miaomiaoRealskin_anima10_txt.safetensors
# LOCAL_IMAGE_COMFYUI_VAE_NAME=qwen_image_vae.safetensors

TTS_LOCAL_HTTP_URL=
TTS_API_KEY=
TTS_TOTAL_TIMEOUT_SECONDS=120
TTS_STALE_JOB_GRACE_SECONDS=30
TTS_PROVIDER_TIMEOUT_SECONDS=30

MATRIX_HOMESERVER=
MATRIX_ACCESS_TOKEN=
AGENT1_MATRIX_ACCESS_TOKEN=
AGENT2_MATRIX_ACCESS_TOKEN=
AGENT3_MATRIX_ACCESS_TOKEN=
MATRIX_TIMEOUT_SECONDS=30
MATRIX_MAX_TEXT_CHARS=4000

PRINTER_BRIDGE_URL=
PRINTER_BRIDGE_API_KEY=
PRINTER_BRIDGE_TIMEOUT_SECONDS=30
PRINTER_MAX_FILE_BYTES=10485760
PRINTER_MAX_COPIES=2
